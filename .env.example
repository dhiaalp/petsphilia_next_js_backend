# Database (Railway provides this automatically with Postgres plugin)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Railway provides this with Redis plugin)
REDIS_URL=redis://default:pass@host:6379

# Secrets (generate random strings for production)
JWT_SECRET=your-jwt-secret-here
COOKIE_SECRET=your-cookie-secret-here

# URLs
STOREFRONT_URL=https://your-storefront.up.railway.app
MEDUSA_ADMIN_URL=https://your-backend.up.railway.app

# Optional: S3-compatible storage for backend/admin uploads
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_ENDPOINT=https://t3.storageapi.dev
FILE_PROXY_URL=https://your-storefront.up.railway.app/api/files
